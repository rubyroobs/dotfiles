#!/usr/bin/env bash

send_app_to_workspace () {
    window_count=$(aerospace list-windows --json --all | jq -re "[ .[] | select(.\"app-name\" == \"$1\") ] | length")
    if [ "$window_count" -gt "0" ] > /dev/null 2>&1; then
        aerospace list-windows --json --all | jq -re ".[] | select(.\"app-name\" == \"$1\") | .\"window-id\"" | xargs -I % aerospace move-node-to-workspace --window-id % $2 > /dev/null 2>&1
        if [ -n "$3" ]; then
            aerospace list-windows --json --all | jq -re ".[] | select(.\"app-name\" == \"$1\") | .\"window-id\"" | xargs -I % aerospace layout --window-id % $3 > /dev/null 2>&1
        fi
    fi
}

current_display_count=$(aerospace list-monitors --count)

{{- if .corp }}
####
# Corp
####

# 1: Chrome (Work)
send_app_to_workspace "Google Chrome" 1 accordion

# 2: DataGrip
send_app_to_workspace "DataGrip" 2 accordion

